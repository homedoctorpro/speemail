# ── Microsoft Azure App Registration ─────────────────────────────────────────
# Create at: https://portal.azure.com > App registrations
# Platform: Web
# Redirect URIs: http://localhost:8765/auth/callback  (local)
#                https://your-app.fly.dev/auth/callback  (production)
# Permissions: Mail.Read, offline_access, User.Read  (all Delegated)
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_TENANT_ID=common          # use your specific tenant ID for org accounts
AZURE_CLIENT_SECRET=            # Certificates & secrets → New client secret
AZURE_REDIRECT_URI=http://localhost:8765/auth/callback

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Speemail behaviour ────────────────────────────────────────────────────────
FOLLOW_UP_DAYS=3
POLL_INTERVAL_MINUTES=15

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8765

# ── Production (Fly.io / server) ─────────────────────────────────────────────
SERVER_MODE=true
APP_PASSWORD=choose-a-strong-password-here
AZURE_REDIRECT_URI=https://your-app.fly.dev/auth/callback
