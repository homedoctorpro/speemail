# ── Microsoft Azure App Registration ─────────────────────────────────────────
# Create at: https://portal.azure.com > App registrations
# Platform: Mobile and desktop
# Redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
# Allow public client flows: Yes
# Permissions: Mail.Read, Mail.ReadWrite, Mail.Send, offline_access, User.Read
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_TENANT_ID=common   # use "common" for personal accounts, or your tenant ID

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Speemail behaviour ────────────────────────────────────────────────────────
# Days without reply before a sent email is flagged for follow-up
FOLLOW_UP_DAYS=3

# How often to check email (minutes)
POLL_INTERVAL_MINUTES=15

# Confidence threshold above which drafts can be auto-sent (future feature)
# Currently unused — all drafts go through approval queue
AUTO_SEND_THRESHOLD=0.95

# Port for the local web dashboard
PORT=8765
